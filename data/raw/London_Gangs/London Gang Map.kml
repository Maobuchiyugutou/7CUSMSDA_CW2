            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AL_Y2X49iWPcQPODoOg6dDdJcuWMpoZgr694G2co0mUDWypk326Zd9NiH_BWxq5x2zHDRaoC-dKLLcaVDCTLaIWhgljbkU0bcV6BdyDBB-rXwY_Qp0my0D_pnS-cIxduIrqaWBf5y8CDtjjnbVAyo56iU8nP3JSVbweh5BaCFPuNBrSlmpxmUYuGIqSSTtUCwY5bXLrGxF2bmzVQN09ixjF_NxONjv3oO3Az4EqtBQTqO6WRmVxs?authuser=0&fife=s16383]]></value>
