            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AL_Y2X51LVt5Cgh5Bq2q4eURxoo-dG1t4d7vzO93WGmGcljfJSoWOMCrqoRH7DBLIjkqNFisuT0MUJk5yOWp-d5QS15ecNM3SamodZNNOP23SNk1iwUQlEfo9S6XGauO2h3FQAoIkQovUSlu-atU8D_t4uW2KQuQfmc5PQmoJQKd3Pnjk2gidpZXjqc0HwQGTHDd7KBfUwTB8ylC3Fjgkn9hdnWZ1CzEAAyEFovPr4vvutMhtG2q?authuser=0&fife=s16383]]></value>
