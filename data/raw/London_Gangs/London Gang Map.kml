            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AL_Y2X4gMa8bFm3H2WxNjbK5r0bxxYCmt9z3T6-yh42BDNZ4GcVRxLyk7_ymOZgBbtDt1NcDuBH6-F-ZmYA2glo3kzrnjLhT973n5Z4pxqZJjf5wmajcCYWMQPr47MaX4tM8946d42G2YkTRkKJNY1EKf9M4JFoBtKeuAfX32yxzmgriCbTbw5r8HalUwRf3-_gkRd3ttus?authuser=0&fife=s16383]]></value>
